rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    // Each user can only read and write their own document.
    match /users/{userId} {
      allow read, update: if isSignedIn() && isOwner(userId);
      // During signup the user creates their own profile — userId must match auth uid.
      allow create: if isSignedIn() && isOwner(userId);
      allow list, delete: if false;
    }

    // ─── Dealerships ──────────────────────────────────────────────────────────
    // Public read so catalog pages work without auth.
    // Writes are restricted to the dealership owner / member.
    match /dealerships/{dealershipId} {
      allow get, list: if true;

      // During signup the user doc does not exist yet, so we cannot call
      // getUserData(). Instead we verify the caller is setting themselves as owner.
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;

      // Update: either the original owner OR a verified member may update.
      // ownerId is immutable after creation.
      allow update: if isSignedIn()
        && request.resource.data.ownerId == resource.data.ownerId
        && (
          resource.data.ownerId == request.auth.uid
          || getUserData().dealershipId == dealershipId
        );

      // Only the original owner can delete.
      allow delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    // ─── Vehicles ─────────────────────────────────────────────────────────────
    // Public read so the storefront catalog works without auth.
    // All writes are restricted to the dealership that owns the vehicle.
    match /vehicles/{vehicleId} {
      allow read: if true;

      // dealershipId must match the caller's dealership.
      allow create: if isSignedIn()
        && getUserData().dealershipId == request.resource.data.dealershipId;

      // dealershipId is immutable — prevents "vehicle theft" between revendas.
      allow update: if isSignedIn()
        && getUserData().dealershipId == resource.data.dealershipId
        && request.resource.data.dealershipId == resource.data.dealershipId;

      allow delete: if isSignedIn()
        && getUserData().dealershipId == resource.data.dealershipId;
    }
  }
}
